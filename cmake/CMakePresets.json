{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "system",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": ""
      }
    },
    {
      "name": "x64-debug",
      "displayName": "PC Debug (x64, system deps)",
      "inherits": "system",
      "binaryDir": "${sourceDir}/build/x86_64/Debug/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/x86_64/Debug",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-release",
      "displayName": "PC Release (x64, system deps)",
      "inherits": "system",
      "binaryDir": "${sourceDir}/build/x86_64/Release/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/x86_64/Release",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "RBS_ROOT": "${sourceDir}/build-tool",
        "VCPKG_ROOT": "${sourceDir}/build-tool/vcpkg",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/build-tool/overlay-ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/build-tool/triplets",
        "RBS_VCPKG_CACHE_DIR": "$env{HOME}/.cache/vcpkg-rbs",
        "VCPKG_DOWNLOADS": "$env{HOME}/.cache/vcpkg-rbs/downloads",
        "VCPKG_BINARY_SOURCES": "clear;files,$env{HOME}/.cache/vcpkg-rbs,readwrite",
        "PATH": "/usr/bin:/bin"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build-tool/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/build-tool/overlay-ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/build-tool/triplets"
      }
    },
    {
      "name": "x64-debug-vcpkg",
      "inherits": "vcpkg",
      "displayName": "PC Debug (x64, vcpkg)",
      "binaryDir": "${sourceDir}/build/x86_64/Debug/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-custom",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/x86_64/Debug",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXE_LINKER_FLAGS": "-L${sourceDir}/build/x86_64/Debug/x64-debug-vcpkg/vcpkg_installed/x64-linux-custom/lib -Wl,-rpath,${sourceDir}/build/x86_64/Debug/x64-debug-vcpkg/vcpkg_installed/x64-linux-custom/lib",
        "CMAKE_SHARED_LINKER_FLAGS": "-L${sourceDir}/build/x86_64/Debug/x64-debug-vcpkg/vcpkg_installed/x64-linux-custom/lib -Wl,-rpath,${sourceDir}/build/x86_64/Debug/x64-debug-vcpkg/vcpkg_installed/x64-linux-custom/lib"
      }
    },
    {
      "name": "x64-release-vcpkg",
      "inherits": "vcpkg",
      "displayName": "PC Release (x64, vcpkg)",
      "binaryDir": "${sourceDir}/build/x86_64/Release/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-custom",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/x86_64/Release",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "arm64-debug-vcpkg",
      "inherits": "vcpkg",
      "displayName": "Robot Debug (ARM64, vcpkg)",
      "binaryDir": "${sourceDir}/build/aarch64/Debug/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-custom",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/aarch64/Debug",
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/build-tool/toolchains/aarch64-linux-gnu.cmake",
        "VCPKG_MANIFEST_FEATURES": ""
      }
    },
    {
      "name": "arm64-release-vcpkg",
      "inherits": "vcpkg",
      "displayName": "Robot Release (ARM64, vcpkg)",
      "binaryDir": "${sourceDir}/build/aarch64/Release/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-custom",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/aarch64/Release",
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/build-tool/toolchains/aarch64-linux-gnu.cmake",
        "VCPKG_MANIFEST_FEATURES": ""
      }
    },
    {
      "name": "arm64-release-vcpkg-docker",
      "inherits": "arm64-release-vcpkg",
      "displayName": "Robot Release ARM64 (Docker, vcpkg under /work)",
      "binaryDir": "${sourceDir}/build/aarch64/Release-docker/${presetName}",
      "environment": {
        "VCPKG_ROOT": "/work/.vcpkg-docker-tool",
        "RBS_VCPKG_CACHE_DIR": "/work/.vcpkg-docker-cache-arm64",
        "VCPKG_DOWNLOADS": "/work/.vcpkg-docker-cache-arm64/downloads",
        "VCPKG_BINARY_SOURCES": "clear;files,/work/.vcpkg-docker-cache-arm64,readwrite"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "/work/.vcpkg-docker-tool/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/aarch64/Release-docker"
      }
    },
    {
      "name": "x64-release-vcpkg-docker",
      "inherits": "x64-release-vcpkg",
      "displayName": "PC Release x64 with ROS (Docker, vcpkg under /work)",
      "binaryDir": "${sourceDir}/build/x86_64/Release-docker/${presetName}",
      "environment": {
        "VCPKG_ROOT": "/work/.vcpkg-docker-tool",
        "RBS_VCPKG_CACHE_DIR": "/work/.vcpkg-docker-cache-x64",
        "VCPKG_DOWNLOADS": "/work/.vcpkg-docker-cache-x64/downloads",
        "VCPKG_BINARY_SOURCES": "clear;files,/work/.vcpkg-docker-cache-x64,readwrite",
        "PATH": "/usr/local/bin:/usr/bin:/bin",
        "CC": "/usr/bin/gcc-8",
        "CXX": "/usr/bin/g++-8"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "/work/.vcpkg-docker-tool/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/x86_64/Release-docker",
        "VCPKG_TARGET_TRIPLET": "x64-linux-custom-release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-debug",
      "configurePreset": "x64-debug"
    },
    {
      "name": "x64-release",
      "configurePreset": "x64-release"
    },
    {
      "name": "x64-debug-vcpkg",
      "configurePreset": "x64-debug-vcpkg",
      "environment": {
        "LIBRARY_PATH": "${sourceDir}/build/x86_64/Debug/x64-debug-vcpkg/vcpkg_installed/x64-linux-custom/lib"
      }
    },
    {
      "name": "x64-release-vcpkg",
      "configurePreset": "x64-release-vcpkg"
    },
    {
      "name": "arm64-debug-vcpkg",
      "configurePreset": "arm64-debug-vcpkg"
    },
    {
      "name": "arm64-release-vcpkg",
      "configurePreset": "arm64-release-vcpkg"
    },
    {
      "name": "arm64-release-vcpkg-docker",
      "configurePreset": "arm64-release-vcpkg-docker"
    },
    {
      "name": "x64-release-vcpkg-docker",
      "configurePreset": "x64-release-vcpkg-docker"
    }
  ]
}